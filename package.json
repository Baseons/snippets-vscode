{
  "name": "baseons",
  "displayName": "Baseons Snippets",
  "description": "HTML-compatible snippets and syntax support for .bns.php files.",
  "version": "0.0.1",
  "publisher": "Baseons",
  "icon": "images/logo.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Snippets",
    "Programming Languages"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:baseons"
  ],
  "contributes": {
    "languages": [
      {
        "id": "baseons",
        "aliases": [
          "Baseons",
          "baseons",
          "base"
        ],
        "filenamePatterns": [
          "*.bns.php",
          "baseons",
          "base",
          "*.html.php"
        ],
        "extensions": [
          ".bns.php",
          ".html.php"
        ],
        "configuration": "language-configuration.json",
        "icon": {
          "light": "images/logo.png",
          "dark": "images/logo.png"
        }
      }
    ],
    "configurationDefaults": {
      "emmet.includeLanguages": {
        "baseons": "html"
      },
      "[baseons]": {
        "editor.defaultFormatter": "vscode.html-language-features"
      }
    },
    "snippets": [
      {
        "language": "baseons",
        "path": "snippets/baseons.json"
      }
    ],
    "grammars": [
      {
        "language": "baseons",
        "scopeName": "text.html.baseons",
        "path": "syntaxes/baseons.tmLanguage.json",
        "embeddedLanguages": {
          "source.php": "php",
          "source.css": "css",
          "source.js": "javascript",
          "meta.embedded.block.javascript.baseons": "javascript",
          "meta.embedded.block.css.baseons": "css"
        }
      }
    ]
  },
  "dependencies": {
    "js-beautify": "^1.15.4"
  }
}
